# App Settings
PROJECT_NAME="FastAPI Auth & Showcase"
ENVIRONMENT="development"
DEBUG=True
API_V1_STR="/api/v1"

# Security
SECRET_KEY="change_this_to_a_super_secret_random_key_in_production_32_bytes_min"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite by default, change to PostgreSQL for production e.g. postgresql+asyncpg://user:pass@host/dbname)
DATABASE_URL="sqlite+aiosqlite:///./fastapi_auth.db"

# CORS Origins (comma separated)
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
